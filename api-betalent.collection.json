{
  "info": {
    "name": "API BeTalent - Multi Gateway",
    "description": "Collection da API principal para Postman/Insomnia.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@betalent.local\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Tem access_token', function () { pm.expect(pm.response.json()).to.have.property('access_token'); });",
                  "pm.environment.set('access_token', pm.response.json().access_token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Purchase",
      "item": [
        {
          "name": "Create Purchase",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_name\": \"Cliente API\",\n  \"client_email\": \"cliente.api@teste.com\",\n  \"card_number\": \"5569000000006063\",\n  \"cvv\": \"010\",\n  \"products\": [\n    { \"product_id\": 1, \"quantity\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/purchase",
              "host": ["{{base_url}}"],
              "path": ["purchase"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "if (body?.data?.id) { pm.environment.set('transaction_id', String(body.data.id)); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Gateways",
      "item": [
        {
          "name": "List Gateways",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/gateways",
              "host": ["{{base_url}}"],
              "path": ["gateways"]
            }
          }
        },
        {
          "name": "Toggle Gateway Active",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/gateways/{{gateway_id}}/active",
              "host": ["{{base_url}}"],
              "path": ["gateways", "{{gateway_id}}", "active"]
            }
          }
        },
        {
          "name": "Update Gateway Priority",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/gateways/{{gateway_id}}/priority",
              "host": ["{{base_url}}"],
              "path": ["gateways", "{{gateway_id}}", "priority"]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User API\",\n  \"email\": \"user.api@teste.com\",\n  \"password\": \"password\",\n  \"role\": \"USER\"\n}"
            },
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        },
        {
          "name": "Show User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        },
        {
          "name": "Update User (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"User API Atualizado\"\n}" },
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        }
      ]
    },
    {
      "name": "05 - Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
